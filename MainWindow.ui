  <!-- 主窗口边距：四周留白增大 -->
  <property name="styleSheet">
   <string notr="true">
    /* 主窗口背景 */
    QMainWindow {
        background-color: #2a2a4a;
        padding: 20px;
    }
    
    /* 通用按钮样式 */
    QPushButton {
        background-color: #16213e;
        color: #e2e2e2;
        border: 1px solid #0f3460;
        border-radius: 8px;
        padding: 10px 20px;
        font-size: 16px;
        font-weight: bold;
        text-align: left;
        padding-left: 15px;
    }
    QPushButton:hover {
        background-color: #0f3460;
        border-color: #e94560;
    }
    QPushButton:pressed {
        background-color: #e94560;
    }
    
    /* 提交按钮特殊样式 */
    QPushButton#pushButton_3 {
        background-color: #e94560;
        border-color: #e94560;
        text-align: center;
        font-size: 18px;
        padding: 12px;
    }
    QPushButton#pushButton_3:hover {
        background-color: #ff6b6b;
    }
    
    /* 标签样式 - 字体放大2倍 */
    QLabel {
        color: #e2e2e2;
        font-size: 16px;
    }
    /* 标题 - 保持之前的放大效果 */
    QLabel#label {
        font-size: 42px;
        font-weight: bold;
        color: #e94560;
        letter-spacing: 3px;
    }
    /* 分组标题标签 */
    QLabel#label_2, QLabel#label_4, QLabel#label_5 {
        font-size: 16px;
        font-weight: bold;
        background-color: #3a6ea5;
        border-radius: 6px;
        padding: 6px;
        color: white;
    }
    
    /* 单选框样式 */
    QRadioButton {
        color: #e2e2e2;
        font-size: 14px;
        spacing: 8px;
    }
    QRadioButton::indicator {
        width: 14px;
        height: 14px;
        border-radius: 7px;
    }
    QRadioButton::indicator:unchecked {
        background-color: #16213e;
        border: 1px solid #0f3460;
    }
    QRadioButton::indicator:checked {
        background-color: #e94560;
        border: 1px solid #e94560;
    }
    
    /* 滚动区域样式 */
    QScrollArea {
        border: 1px solid #0f3460;
        border-radius: 8px;
        background-color: #1a1a3a;
    }
    
    /* 状态标签 - 字体放大 */
    QLabel#label_3 {
        background-color: #1a1a3a;
        border: 1px solid #0f3460;
        border-radius: 8px;
        padding: 12px;
        font-family: monospace;
        font-size: 14px;
    }
    
    /* 分组面板样式 - 更浅的蓝色背景 */
    QWidget#resolution_widget, QWidget#mode_widget {
        background-color: #3a6ea5;
        border-radius: 10px;
        padding: 10px;
    }
    /* 分组面板内的标签文字颜色 */
    QWidget#resolution_widget QLabel, QWidget#mode_widget QLabel {
        color: white;
        font-weight: bold;
    }
    /* 分组面板内的单选框文字颜色 */
    QWidget#resolution_widget QRadioButton, QWidget#mode_widget QRadioButton {
        color: white;
        font-size: 14px;
    }
   </string>
  </property>
  
